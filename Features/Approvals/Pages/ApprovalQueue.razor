@page "/admin/approvals"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireDepartmentHead")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<PageTitle>Approval Queue — Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Approval Queue</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    <MudTabPanel Text="Pending" BadgeData="@_pendingCount" BadgeColor="Color.Warning">
        <ApprovalTable Items="_pending" OnAction="HandleAction" />
    </MudTabPanel>
    <MudTabPanel Text="Approved">
        <ApprovalTable Items="_approved" ReadOnly="true" />
    </MudTabPanel>
    <MudTabPanel Text="Rejected">
        <ApprovalTable Items="_rejected" ReadOnly="true" />
    </MudTabPanel>
</MudTabs>

@code {
    private List<ApprovalWorkflow> _pending = [];
    private List<ApprovalWorkflow> _approved = [];
    private List<ApprovalWorkflow> _rejected = [];
    private int _pendingCount;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        var workflows = await context.ApprovalWorkflows
            .Include(w => w.Requester)
            .OrderByDescending(w => w.RequestDate)
            .AsNoTracking()
            .ToListAsync();

        _pending = workflows.Where(w => w.CurrentStatus == ApprovalStatus.PendingApproval).ToList();
        _approved = workflows.Where(w => w.CurrentStatus == ApprovalStatus.Approved).ToList();
        _rejected = workflows.Where(w => w.CurrentStatus == ApprovalStatus.Rejected).ToList();
        _pendingCount = _pending.Count;
    }

    private async Task HandleAction((int WorkflowId, ApprovalStatus NewStatus, string? Comments) action)
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        var workflow = await context.ApprovalWorkflows.FindAsync(action.WorkflowId);
        if (workflow is null) return;

        var oldStatus = workflow.CurrentStatus;
        workflow.CurrentStatus = action.NewStatus;
        workflow.ResolutionDate = DateTime.UtcNow;
        workflow.ResolutionComments = action.Comments;

        context.ApprovalHistory.Add(new ApprovalHistory
        {
            WorkflowId = workflow.Id,
            Action = action.NewStatus == ApprovalStatus.Approved ? ApprovalAction.Approved : ApprovalAction.Rejected,
            Comments = action.Comments,
            OldStatus = oldStatus.ToString(),
            NewStatus = action.NewStatus.ToString(),
        });

        await context.SaveChangesAsync();
        Snackbar.Add($"Item {action.NewStatus.ToString().ToLower()}", Severity.Success);
        await LoadData();
    }
}
