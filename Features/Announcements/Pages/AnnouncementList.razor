@page "/admin/announcements"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireContentCreator")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Manage Announcements — Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">Announcements</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage company announcements and notices</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog"
               Style="text-transform: none;">
        New Announcement
    </MudButton>
</div>

<MudPaper Elevation="2" Class="pa-5" Style="border-radius: 12px;">
    <MudTable Items="@_announcements" Hover="true" Dense="true" Elevation="0"
              Loading="@_loading" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Priority</MudTh>
            <MudTh>Publish Date</MudTh>
            <MudTh>Expiry Date</MudTh>
            <MudTh>Active</MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Priority">
                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">
                    @context.Priority
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Publish">@(context.PublishDate?.ToString("d") ?? "—")</MudTd>
            <MudTd DataLabel="Expiry">@(context.ExpiryDate?.ToString("d") ?? "—")</MudTd>
            <MudTd DataLabel="Active">
                <MudIcon Icon="@(context.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                         Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small" />
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteAnnouncement(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No announcements found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<!-- Create / Edit Dialog -->
<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Edit Announcement" : "New Announcement")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_title" Label="Title" Required="true"
                          RequiredError="Title is required" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_content" Label="Content" Lines="4"
                          Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_priority" Label="Priority" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var p in Enum.GetValues<AnnouncementPriority>())
                {
                    <MudSelectItem T="AnnouncementPriority" Value="@p">@p</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker @bind-Date="_publishDate" Label="Publish Date"
                           Variant="Variant.Outlined" Class="mb-3" />
            <MudDatePicker @bind-Date="_expiryDate" Label="Expiry Date"
                           Variant="Variant.Outlined" Class="mb-3" />
            <MudSwitch @bind-Value="_isActive" Label="Active" Color="Color.Success" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAnnouncement">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Announcement> _announcements = [];
    private bool _loading = true;
    private bool _dialogVisible;
    private MudForm? _form;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    // Form fields
    private int? _editingId;
    private string _title = "";
    private string _content = "";
    private AnnouncementPriority _priority = AnnouncementPriority.Medium;
    private DateTime? _publishDate;
    private DateTime? _expiryDate;
    private bool _isActive = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            _announcements = await context.Announcements
                .OrderByDescending(a => a.PublishDate)
                .AsNoTracking()
                .ToListAsync();
        }
        finally { _loading = false; }
    }

    private void OpenCreateDialog()
    {
        _editingId = null;
        _title = "";
        _content = "";
        _priority = AnnouncementPriority.Medium;
        _publishDate = DateTime.Today;
        _expiryDate = null;
        _isActive = true;
        _dialogVisible = true;
    }

    private void OpenEditDialog(Announcement item)
    {
        _editingId = item.Id;
        _title = item.Title;
        _content = item.Content ?? "";
        _priority = item.Priority;
        _publishDate = item.PublishDate;
        _expiryDate = item.ExpiryDate;
        _isActive = item.IsActive;
        _dialogVisible = true;
    }

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveAnnouncement()
    {
        if (_form is not null) await _form.Validate();
        if (_form?.IsValid != true) return;

        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        if (_editingId.HasValue)
        {
            var entity = await context.Announcements.FindAsync(_editingId.Value);
            if (entity is null) return;
            entity.Title = _title;
            entity.Content = _content;
            entity.Priority = _priority;
            entity.PublishDate = _publishDate;
            entity.ExpiryDate = _expiryDate;
            entity.IsActive = _isActive;
        }
        else
        {
            context.Announcements.Add(new Announcement
            {
                Title = _title,
                Content = _content,
                Priority = _priority,
                PublishDate = _publishDate,
                ExpiryDate = _expiryDate,
                IsActive = _isActive
            });
        }

        await context.SaveChangesAsync();
        Snackbar.Add(_editingId.HasValue ? "Announcement updated" : "Announcement created", Severity.Success);
        CloseDialog();
        await LoadData();
    }

    private async Task DeleteAnnouncement(Announcement item)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Announcement",
            $"Are you sure you want to delete \"{item.Title}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var entity = await context.Announcements.FindAsync(item.Id);
            if (entity is not null)
            {
                context.Announcements.Remove(entity);
                await context.SaveChangesAsync();
                Snackbar.Add("Announcement deleted", Severity.Success);
                await LoadData();
            }
        }
    }

    private static Color GetPriorityColor(AnnouncementPriority priority) => priority switch
    {
        AnnouncementPriority.High => Color.Error,
        AnnouncementPriority.Medium => Color.Warning,
        AnnouncementPriority.Low => Color.Info,
        _ => Color.Default
    };
}
