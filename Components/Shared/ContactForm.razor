@* Contact/inquiry form component *@
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
    <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-4"
             Style="font-family: 'Rajdhani', sans-serif;">
        @Title
    </MudText>

    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.ContactName" Label="Full Name" Required="true"
                              RequiredError="Name is required" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.CompanyName" Label="Company Name"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.Email" Label="Email" Required="true"
                              RequiredError="Email is required" InputType="InputType.Email"
                              Validation="@(new Func<string, string?>(ValidateEmail))"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.Phone" Label="Phone Number"
                              Variant="Variant.Outlined" />
            </MudItem>
            @if (ShowServiceSelector)
            {
                <MudItem xs="12">
                    <MudSelect @bind-Value="_model.ServiceInterest" Label="Service of Interest"
                               Variant="Variant.Outlined" Clearable="true">
                        @foreach (var cat in _categories)
                        {
                            <MudSelectItem T="string" Value="@cat.Name">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Message" Label="Message" Required="true"
                              RequiredError="Message is required" Lines="5"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Disabled="@(!_formValid || _submitting)"
                           OnClick="HandleSubmit"
                           StartIcon="@Icons.Material.Filled.Send"
                           Style="text-transform: none;">
                    @if (_submitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Sending...</text>
                    }
                    else
                    {
                        <text>Send Message</text>
                    }
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

@code {
    private MudForm _form = null!;
    private bool _formValid;
    private bool _submitting;
    private ContactModel _model = new();
    private List<ServiceCategory> _categories = [];

    [Parameter] public string Title { get; set; } = "Get in Touch";
    [Parameter] public bool ShowServiceSelector { get; set; } = true;
    [Parameter] public EventCallback<ContactModel> OnSubmit { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        _categories = await context.ServiceCategories
            .Where(c => c.IsActive)
            .OrderBy(c => c.DisplayOrder)
            .AsNoTracking()
            .ToListAsync();
    }

    private string? ValidateEmail(string email)
    {
        if (string.IsNullOrEmpty(email)) return null;
        if (!email.Contains('@') || !email.Contains('.'))
            return "Please enter a valid email address";
        return null;
    }

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_formValid) return;

        _submitting = true;
        try
        {
            if (OnSubmit.HasDelegate)
            {
                await OnSubmit.InvokeAsync(_model);
            }
            Snackbar.Add("Your message has been sent successfully! We'll get back to you soon.", Severity.Success);
            _model = new();
            await _form.ResetAsync();
        }
        finally
        {
            _submitting = false;
        }
    }

    public class ContactModel
    {
        public string ContactName { get; set; } = string.Empty;
        public string? CompanyName { get; set; }
        public string Email { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public string? ServiceInterest { get; set; }
        public string Message { get; set; } = string.Empty;
    }
}
