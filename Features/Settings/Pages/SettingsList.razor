@page "/admin/settings"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireManagement")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@using OECLWebsite.Infrastructure.Services
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IEmailService EmailService

<PageTitle>Settings — Oval Engineering Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">System Settings</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Configure email and application settings</MudText>
    </div>
    <div class="d-flex gap-3">
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="SendTestEmail"
                   Disabled="@_saving"
                   Style="text-transform: none;">
            Send Test Email
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveSettings"
                   Disabled="@_saving"
                   Style="text-transform: none;">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <text>Saving...</text>
            }
            else
            {
                <text>Save Settings</text>
            }
        </MudButton>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex justify-center pa-12">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else
{
    @foreach (var group in _grouped)
    {
        <MudPaper Elevation="2" Class="pa-6 mb-5" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-1" Style="font-family: 'Rajdhani', sans-serif;">
                @group.Key Settings
            </MudText>
            <div class="divider-accent-left mb-5"></div>
            <MudGrid Spacing="4">
                @foreach (var setting in group.Value)
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="setting.Value"
                                      Label="@setting.Key.Split(':').Last()"
                                      HelperText="@setting.Description"
                                      InputType="@(setting.IsSecret ? InputType.Password : InputType.Text)"
                                      Variant="Variant.Outlined"
                                      Adornment="@(setting.IsSecret ? Adornment.End : Adornment.None)"
                                      AdornmentIcon="@(setting.IsSecret ? Icons.Material.Filled.Lock : "")" />
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }
}

@code {
    private bool _loading = true;
    private bool _saving;
    private List<SystemSetting> _settings = [];
    private Dictionary<string, List<SystemSetting>> _grouped = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        _loading = true;
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        _settings = await context.SystemSettings
            .OrderBy(s => s.Category)
            .ThenBy(s => s.Key)
            .ToListAsync();

        _grouped = _settings
            .GroupBy(s => s.Category)
            .ToDictionary(g => g.Key, g => g.ToList());

        _loading = false;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            foreach (var setting in _settings)
            {
                var dbSetting = await context.SystemSettings.FindAsync(setting.Id);
                if (dbSetting is not null)
                {
                    dbSetting.Value = setting.Value;
                }
            }

            await context.SaveChangesAsync();
            Snackbar.Add("Settings saved successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SendTestEmail()
    {
        var toSetting = _settings.FirstOrDefault(s => s.Key == "Email:To");
        if (string.IsNullOrWhiteSpace(toSetting?.Value))
        {
            Snackbar.Add("Please configure the Email:To setting before sending a test email.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await EmailService.SendTestEmailAsync(toSetting.Value);
            Snackbar.Add($"Test email sent to {toSetting.Value}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Test email failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
