@page "/about"
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider

<PageTitle>About Us — Oval Engineering Company Limited</PageTitle>

<!-- Hero -->
<MudPaper Class="@(_heroUrl != null ? "hero-page-photo pa-12" : "hero-page pa-12")"
          Style="@(_heroUrl != null ? $"background-image: url('{_heroUrl}');" : "")"
          Square="true" Elevation="0">
    <MudContainer MaxWidth="MaxWidth.Large" Style="position: relative; z-index: 1;">
        <MudText Typo="Typo.overline" Style="color: #F97316; letter-spacing: 2px;">ABOUT US</MudText>
        <MudText Typo="Typo.h3" Style="color: #F8FAFC; font-family: 'Rajdhani', sans-serif; font-weight: 700;">
            About Oval Engineering
        </MudText>
        <MudText Typo="Typo.body1" Style="color: #94A3B8;" Class="mt-2">
            Engineering Excellence in South Sudan's Oil & Gas Sector
        </MudText>
    </MudContainer>
</MudPaper>

<!-- Company Overview -->
<MudContainer MaxWidth="MaxWidth.Large" Class="py-16">
    <MudGrid Spacing="8">
        <MudItem xs="12" md="7">
            <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2"
                     Style="font-family: 'Rajdhani', sans-serif;">
                Who We Are
            </MudText>
            <div class="divider-accent-left mb-6"></div>
            <MudText Typo="Typo.body1" Class="mb-4" Style="line-height: 1.8;">
                Oval Engineering Company Limited is a leading Oil & Gas engineering services provider
                headquartered in Juba, South Sudan. We deliver comprehensive engineering solutions
                across the full project lifecycle — from Front-End Engineering Design (FEED) through
                construction, commissioning, and ongoing operations and maintenance.
            </MudText>
            <MudText Typo="Typo.body1" Style="line-height: 1.8;">
                Our team of experienced engineers and project managers brings deep technical expertise
                and local knowledge to every engagement, ensuring projects are delivered safely, on time,
                and within budget.
            </MudText>
        </MudItem>
        <MudItem xs="12" md="5" Class="d-flex align-center justify-center">
            <MudPaper Elevation="0" Class="pa-6" Style="background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%); border-radius: 16px; width: 100%;">
                <MudGrid>
                    <MudItem xs="6" Class="text-center pa-4">
                        <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">10+</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Years Experience</MudText>
                    </MudItem>
                    <MudItem xs="6" Class="text-center pa-4">
                        <MudText Typo="Typo.h3" Color="Color.Secondary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">50+</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Projects Delivered</MudText>
                    </MudItem>
                    <MudItem xs="6" Class="text-center pa-4">
                        <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">100+</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Team Members</MudText>
                    </MudItem>
                    <MudItem xs="6" Class="text-center pa-4">
                        <MudText Typo="Typo.h3" Color="Color.Secondary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">5</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Core Services</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- Vision, Mission, Values -->
<MudPaper Class="section-alt py-16" Square="true" Elevation="0">
    <MudContainer MaxWidth="MaxWidth.Large">
        <div class="text-center mb-10">
            <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-family: 'Rajdhani', sans-serif;">
                Vision, Mission & Values
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2 mb-3">
                The principles that guide our work
            </MudText>
            <div class="divider-accent"></div>
        </div>

        <MudGrid Spacing="6">
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="h-100 value-card value-card-primary">
                    <MudCardContent Class="text-center pa-8">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Variant="Variant.Outlined"
                                   Style="width: 64px; height: 64px; margin-bottom: 1.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Visibility" />
                        </MudAvatar>
                        <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-3"
                                 Style="font-family: 'Rajdhani', sans-serif;">Our Vision</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            To be the premier engineering services company in East Africa,
                            recognized for technical excellence, innovation, and commitment to
                            sustainable development in the Oil & Gas sector.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="h-100 value-card value-card-secondary">
                    <MudCardContent Class="text-center pa-8">
                        <MudAvatar Color="Color.Secondary" Size="Size.Large" Variant="Variant.Outlined"
                                   Style="width: 64px; height: 64px; margin-bottom: 1.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Flag" />
                        </MudAvatar>
                        <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-3"
                                 Style="font-family: 'Rajdhani', sans-serif;">Our Mission</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            To deliver world-class engineering solutions that meet the highest
                            standards of safety, quality, and efficiency while developing local
                            talent and contributing to South Sudan's economic growth.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="h-100 value-card value-card-tertiary">
                    <MudCardContent Class="text-center pa-8">
                        <MudAvatar Color="Color.Tertiary" Size="Size.Large" Variant="Variant.Outlined"
                                   Style="width: 64px; height: 64px; margin-bottom: 1.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Diamond" />
                        </MudAvatar>
                        <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-3"
                                 Style="font-family: 'Rajdhani', sans-serif;">Our Values</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Safety First, Technical Excellence, Integrity, Innovation,
                            Local Empowerment, and Environmental Responsibility drive
                            everything we do.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudPaper>

<!-- Core Values Detail -->
<MudContainer MaxWidth="MaxWidth.Large" Class="py-16">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-family: 'Rajdhani', sans-serif;">
            Our Core Values
        </MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2 mb-3">
            The foundation of our operations
        </MudText>
        <div class="divider-accent"></div>
    </div>

    <MudGrid Spacing="4">
        @foreach (var value in _coreValues)
        {
            <MudItem xs="12" sm="6" md="4">
                <div class="feature-item d-flex align-start gap-3">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@value.Icon" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mb-1">@value.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@value.Description</MudText>
                    </div>
                </div>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private string? _heroUrl;

    private record CoreValue(string Icon, string Title, string Description);

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var photo = await context.SitePhotos
            .Where(p => p.PhotoKey == "hero-about" && p.IsActive && !string.IsNullOrEmpty(p.ImageUrl))
            .AsNoTracking()
            .FirstOrDefaultAsync();
        _heroUrl = photo?.ImageUrl;
    }

    private readonly List<CoreValue> _coreValues =
    [
        new(Icons.Material.Filled.Security, "Safety First", "Zero-harm workplace with rigorous HSE standards on every project."),
        new(Icons.Material.Filled.Star, "Technical Excellence", "Best-in-class engineering practices and continuous professional development."),
        new(Icons.Material.Filled.Handshake, "Integrity", "Transparent, ethical business conduct in all relationships."),
        new(Icons.Material.Filled.Lightbulb, "Innovation", "Adopting cutting-edge technologies and methodologies for superior outcomes."),
        new(Icons.Material.Filled.People, "Local Empowerment", "Developing South Sudanese talent and supporting community growth."),
        new(Icons.Material.Filled.Park, "Sustainability", "Minimizing environmental impact through responsible engineering practices."),
    ];
}
