@page "/admin/dashboard"
@layout AdminLayout
@attribute [Authorize]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider

<PageTitle>Dashboard — Oval Engineering Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">Dashboard</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Overview of your engineering operations</MudText>
    </div>
    <MudButton Href="/" Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
               Style="text-transform: none;">
        View Site
    </MudButton>
</div>

<!-- Stat Cards -->
<MudGrid Class="mb-6" Spacing="4">
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 stat-card stat-card-primary">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Services</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">@_totalServices</MudText>
                </div>
                <div class="stat-icon stat-icon-primary">
                    <MudIcon Icon="@Icons.Material.Filled.Engineering" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 stat-card stat-card-info">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Projects</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Info" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">@_totalProjects</MudText>
                </div>
                <div class="stat-icon stat-icon-info">
                    <MudIcon Icon="@Icons.Material.Filled.Business" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 stat-card stat-card-warning">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Pending Approvals</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">@_pendingApprovals</MudText>
                </div>
                <div class="stat-icon stat-icon-warning">
                    <MudIcon Icon="@Icons.Material.Filled.HourglassTop" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 stat-card stat-card-success">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">New Inquiries</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">@_newInquiries</MudText>
                </div>
                <div class="stat-icon stat-icon-success">
                    <MudIcon Icon="@Icons.Material.Filled.Mail" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 stat-card stat-card-secondary">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Gallery Images</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Secondary" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700;">@_galleryImages</MudText>
                </div>
                <div class="stat-icon stat-icon-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Collections" />
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Quick Actions -->
<MudGrid Spacing="4">
    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-5" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-family: 'Rajdhani', sans-serif;">Quick Actions</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudButton Href="/admin/services/new" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" FullWidth="true"
                               Style="text-transform: none; justify-content: flex-start; padding: 12px 16px;">
                        Add New Service
                    </MudButton>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudButton Href="/admin/projects/new" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" FullWidth="true"
                               Style="text-transform: none; justify-content: flex-start; padding: 12px 16px;">
                        Add New Project
                    </MudButton>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudButton Href="/admin/inquiries" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Email" FullWidth="true"
                               Style="text-transform: none; justify-content: flex-start; padding: 12px 16px;">
                        View Inquiries
                    </MudButton>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudButton Href="/admin/approvals" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CheckCircle" FullWidth="true"
                               Style="text-transform: none; justify-content: flex-start; padding: 12px 16px;">
                        Review Approvals
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="2" Class="pa-5" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-family: 'Rajdhani', sans-serif;">System Status</MudText>
            <div class="d-flex align-center gap-3 mb-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.body2">Website Online</MudText>
            </div>
            <div class="d-flex align-center gap-3 mb-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.body2">Database Connected</MudText>
            </div>
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.body2">File Uploads Active</MudText>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int _totalServices;
    private int _totalProjects;
    private int _pendingApprovals;
    private int _newInquiries;
    private int _galleryImages;

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        _totalServices = await context.Services.CountAsync();
        _totalProjects = await context.Projects.CountAsync();
        _pendingApprovals = await context.Services.CountAsync(s => s.ApprovalStatus == ApprovalStatus.PendingApproval)
            + await context.Projects.CountAsync(p => p.ApprovalStatus == ApprovalStatus.PendingApproval);
        _newInquiries = await context.ServiceInquiries.CountAsync(i => i.Status == InquiryStatus.New);
        _galleryImages = await context.GalleryImages.CountAsync(g => g.IsActive);
    }
}
