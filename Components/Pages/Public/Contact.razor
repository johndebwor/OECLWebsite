@page "/contact"
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@using OECLWebsite.Infrastructure.Services
@inject IEmailService EmailService

<PageTitle>Contact Us — Oval Engineering Company Limited</PageTitle>

<!-- Hero -->
<MudPaper Class="@(_heroUrl != null ? "hero-page-photo pa-12" : "hero-page pa-12")"
          Style="@(_heroUrl != null ? $"background-image: url('{_heroUrl}');" : "")"
          Square="true" Elevation="0">
    <MudContainer MaxWidth="MaxWidth.Large" Style="position: relative; z-index: 1;">
        <MudText Typo="Typo.overline" Style="color: #F97316; letter-spacing: 2px;">GET IN TOUCH</MudText>
        <MudText Typo="Typo.h3" Style="color: #F8FAFC; font-family: 'Rajdhani', sans-serif; font-weight: 700;">
            Contact Us
        </MudText>
        <MudText Typo="Typo.body1" Style="color: #94A3B8;" Class="mt-2">
            Let's discuss how we can support your engineering needs
        </MudText>
    </MudContainer>
</MudPaper>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-12">
    <MudGrid Spacing="6">
        <!-- Contact Form -->
        <MudItem xs="12" md="7">
            <ContactForm Title="Send Us a Message" OnSubmit="HandleContactSubmit" />
        </MudItem>

        <!-- Contact Info -->
        <MudItem xs="12" md="5">
            <MudPaper Elevation="2" Class="pa-6 mb-5" Style="border-radius: 12px;">
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-2"
                         Style="font-family: 'Rajdhani', sans-serif;">
                    Office Location
                </MudText>
                <div class="divider-accent-left mb-5"></div>

                <div class="d-flex align-start gap-3 mb-4">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.subtitle2">Head Office</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Amarat, Juba<br />
                            Republic of South Sudan
                        </MudText>
                    </div>
                </div>
                <div class="d-flex align-start gap-3 mb-4">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.subtitle2">Phone</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">+211 (0) 912 000 000</MudText>
                    </div>
                </div>
                <div class="d-flex align-start gap-3 mb-4">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.subtitle2">Email</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">info@oecl-ss.com</MudText>
                    </div>
                </div>
                <div class="d-flex align-start gap-3">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.subtitle2">Business Hours</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Sunday — Thursday: 8:00 AM — 5:00 PM<br />
                            Friday — Saturday: Closed
                        </MudText>
                    </div>
                </div>
            </MudPaper>

            <!-- Department Directory -->
            <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-2"
                         Style="font-family: 'Rajdhani', sans-serif;">
                    Department Directory
                </MudText>
                <div class="divider-accent-left mb-5"></div>
                @foreach (var dept in _departments)
                {
                    <div class="d-flex justify-space-between align-center py-3">
                        <MudText Typo="Typo.body2">@dept.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-size: 0.8rem;">@dept.Contact</MudText>
                    </div>
                    <MudDivider />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- Google Map -->
<MudPaper Square="true" Elevation="1">
    <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.8!2d36.763036027463706!3d-1.2683244453893678!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMcKwMTYnMDYuMCJTIDM2wrA0NSc0Ni45IkU!5e0!3m2!1sen!4v1"
        width="100%"
        height="1520"
        style="border:0; display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
    </iframe>
</MudPaper>

@code {
    private string? _heroUrl;

    private record Department(string Name, string Contact);

    private readonly List<Department> _departments =
    [
        new("Engineering & Design", "engineering@oecl-ss.com"),
        new("Construction", "construction@oecl-ss.com"),
        new("Operations & Maintenance", "operations@oecl-ss.com"),
        new("Project Management", "projects@oecl-ss.com"),
        new("Human Resources", "hr@oecl-ss.com"),
        new("Finance", "finance@oecl-ss.com"),
    ];

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var photo = await context.SitePhotos
            .Where(p => p.PhotoKey == "hero-contact" && p.IsActive && !string.IsNullOrEmpty(p.ImageUrl))
            .AsNoTracking()
            .FirstOrDefaultAsync();
        _heroUrl = photo?.ImageUrl;
    }

    private async Task HandleContactSubmit(ContactForm.ContactModel model)
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        var inquiry = new ServiceInquiry
        {
            ContactName = model.ContactName,
            CompanyName = model.CompanyName,
            Email = model.Email,
            Phone = model.Phone,
            Message = model.Message,
            ServiceInterest = model.ServiceInterest,
            InquiryDate = DateTime.UtcNow,
            Status = InquiryStatus.New,
        };

        context.ServiceInquiries.Add(inquiry);
        await context.SaveChangesAsync();

        // Send email notification (fire-and-forget style; failure does not affect the user)
        try
        {
            await EmailService.SendContactInquiryAsync(
                model.ContactName, model.Email, model.CompanyName,
                model.Phone, model.ServiceInterest, model.Message);
        }
        catch (Exception)
        {
            // Logged inside SmtpEmailService; inquiry is already saved so we don't surface the error
        }
    }
}
