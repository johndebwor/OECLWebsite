@inherits LayoutComponentBase
@attribute [Authorize]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider

<MudThemeProvider Theme="OvalTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Dense="true" Style="background: #0F172A;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        @if (!string.IsNullOrEmpty(_logoUrl))
        {
            <MudImage Src="@_logoUrl" Alt="OECL Logo" Height="32" Class="ml-2" ObjectFit="ObjectFit.Contain" />
        }
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-family: 'Rajdhani', sans-serif; font-weight: 700; letter-spacing: 1px;">
            OVAL ENGINEERING
        </MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                 Style="color: #F97316; border-color: #F97316; margin-left: 12px;">
            Admin
        </MudChip>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Home" Href="/">Back to Site</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" Href="/auth/logout">Sign Out</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Lg">
        <AdminNavMenu />
    </MudDrawer>

    <MudMainContent Style="padding: 72px 24px 24px 24px;">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private string? _logoUrl;

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var logo = await context.SitePhotos
            .Where(p => p.PhotoKey == "company-logo" && p.IsActive && !string.IsNullOrEmpty(p.ImageUrl))
            .AsNoTracking()
            .FirstOrDefaultAsync();
        _logoUrl = logo?.ImageUrl;
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
