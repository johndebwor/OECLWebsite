@page "/admin/project-types"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireContentCreator")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<PageTitle>Project Types — Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">Project Types</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage project type options shown in the project form</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Save"
               OnClick="Save"
               Disabled="@_saving"
               Style="text-transform: none;">
        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
        Save Changes
    </MudButton>
</div>

@if (_loading)
{
    <div class="d-flex justify-center pa-12">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else
{
    <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
            Add or remove project type options. Each type appears in the dropdown when creating or editing a project.
        </MudText>

        <!-- Existing types as chips -->
        <div class="d-flex flex-wrap gap-2 mb-6">
            @foreach (var type in _types)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined"
                         OnClose="@(() => RemoveType(type))"
                         Style="font-weight: 500;">
                    @type
                </MudChip>
            }
            @if (!_types.Any())
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="py-2">
                    No project types defined. Add one below.
                </MudText>
            }
        </div>

        <!-- Add new type -->
        <div class="d-flex align-center gap-3">
            <MudTextField @bind-Value="_newType" Label="New Project Type" Variant="Variant.Outlined"
                          Placeholder="e.g. EPCC" Style="max-width: 320px;"
                          OnKeyDown="@HandleKeyDown" />
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddType"
                       Style="text-transform: none;">
                Add
            </MudButton>
        </div>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private List<string> _types = [];
    private string _newType = "";
    private int _settingId;

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var setting = await context.SystemSettings
            .FirstOrDefaultAsync(s => s.Key == "Projects:Types");

        if (setting is not null)
        {
            _settingId = setting.Id;
            _types = (setting.Value ?? string.Empty)
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }

        _loading = false;
    }

    private void AddType()
    {
        var trimmed = _newType.Trim();
        if (!string.IsNullOrEmpty(trimmed) && !_types.Contains(trimmed, StringComparer.OrdinalIgnoreCase))
        {
            _types.Add(trimmed);
        }
        _newType = "";
    }

    private void RemoveType(string type) => _types.Remove(type);

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddType();
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var setting = await context.SystemSettings
                .FirstOrDefaultAsync(s => s.Key == "Projects:Types");

            if (setting is null)
            {
                context.SystemSettings.Add(new SystemSetting
                {
                    Key = "Projects:Types",
                    Value = string.Join(",", _types),
                    Description = "Comma-separated list of project type options",
                    Category = "General"
                });
            }
            else
            {
                setting.Value = string.Join(",", _types);
            }

            await context.SaveChangesAsync();
            Snackbar.Add("Project types saved.", Severity.Success);
        }
        finally { _saving = false; }
    }
}
