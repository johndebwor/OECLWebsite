@page "/admin/services"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireContentCreator")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Manage Services — Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">Services</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage your engineering service offerings</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/admin/services/new"
               Style="text-transform: none;">
        Add Service
    </MudButton>
</div>

<MudPaper Elevation="2" Class="pa-5" Style="border-radius: 12px;">
    <MudTextField @bind-Value="_searchString" Placeholder="Search services..."
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" Variant="Variant.Outlined" Class="mb-4" />

    <MudTable Items="@FilteredServices" Hover="true" Dense="true" Elevation="0"
              Loading="@_loading" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Featured</MudTh>
            <MudTh>Order</MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Category">@context.Category?.Name</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.ApprovalStatus)">
                    @context.ApprovalStatus
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Featured">
                <MudIcon Icon="@(context.IsFeatured ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                         Color="@(context.IsFeatured ? Color.Warning : Color.Default)" Size="Size.Small" />
            </MudTd>
            <MudTd DataLabel="Order">@context.DisplayOrder</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Href="@($"/admin/services/edit/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteService(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No services found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<Service> _services = [];
    private bool _loading = true;
    private string _searchString = "";

    private IEnumerable<Service> FilteredServices => string.IsNullOrEmpty(_searchString)
        ? _services
        : _services.Where(s =>
            s.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            (s.Category?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await LoadServices();

    private async Task LoadServices()
    {
        _loading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            _services = await context.Services
                .Include(s => s.Category)
                .OrderBy(s => s.DisplayOrder)
                .AsNoTracking()
                .ToListAsync();
        }
        finally { _loading = false; }
    }

    private async Task DeleteService(Service service)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Service",
            $"Are you sure you want to delete \"{service.Title}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var entity = await context.Services.FindAsync(service.Id);
            if (entity is not null)
            {
                context.Services.Remove(entity);
                await context.SaveChangesAsync();
                Snackbar.Add("Service deleted successfully", Severity.Success);
                await LoadServices();
            }
        }
    }

    private static Color GetStatusColor(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Draft => Color.Default,
        ApprovalStatus.PendingApproval => Color.Warning,
        ApprovalStatus.Approved => Color.Success,
        ApprovalStatus.Rejected => Color.Error,
        _ => Color.Default
    };
}
