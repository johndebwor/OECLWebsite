@page "/projects"
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore

<PageTitle>Project Portfolio — Oval Engineering Company Limited</PageTitle>

<!-- Hero -->
<MudPaper Class="@(_heroUrl != null ? "hero-page-photo pa-12" : "hero-page pa-12")"
          Style="@(_heroUrl != null ? $"background-image: url('{_heroUrl}');" : "")"
          Square="true" Elevation="0">
    <MudContainer MaxWidth="MaxWidth.Large" Style="position: relative; z-index: 1;">
        <MudText Typo="Typo.overline" Style="color: #F97316; letter-spacing: 2px;">OUR WORK</MudText>
        <MudText Typo="Typo.h3" Style="color: #F8FAFC; font-family: 'Rajdhani', sans-serif; font-weight: 700;">
            Project Portfolio
        </MudText>
        <MudText Typo="Typo.body1" Style="color: #94A3B8;" Class="mt-2">
            Showcasing our track record of engineering excellence
        </MudText>
    </MudContainer>
</MudPaper>

<!-- Project Grid -->
<MudContainer MaxWidth="MaxWidth.Large" Class="py-12">
    @if (_loading)
    {
        <div class="d-flex justify-center pa-12">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </div>
    }
    else if (!_projects.Any())
    {
        <MudPaper Elevation="0" Class="pa-16 text-center" Style="border: 2px dashed #E2E8F0; border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">No projects found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                Projects will appear here once they are added and approved.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="6">
            @foreach (var project in _projects)
            {
                <MudItem xs="12" sm="6" md="4">
                    <ProjectCard ProjectName="@project.ProjectName"
                                 Client="@project.Client"
                                 Location="@project.Location"
                                 ProjectType="@project.ProjectType"
                                 Description="@project.Description"
                                 Status="@project.Status.ToString()"
                                 ImageUrl="@project.FeaturedImageUrl" />
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [Inject] private IServiceProvider ServiceProvider { get; set; } = null!;

    private List<Project> _projects = [];
    private bool _loading = true;
    private string? _heroUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var hero = await context.SitePhotos
                .Where(p => p.PhotoKey == "hero-projects" && p.IsActive && !string.IsNullOrEmpty(p.ImageUrl))
                .AsNoTracking()
                .FirstOrDefaultAsync();
            _heroUrl = hero?.ImageUrl;

            _projects = await context.Projects
                .Where(p => p.ApprovalStatus == ApprovalStatus.Approved)
                .OrderByDescending(p => p.IsShowcase)
                .ThenByDescending(p => p.StartDate)
                .AsNoTracking()
                .ToListAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
