@page "/admin/equipment"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireContentCreator")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Manage Equipment — Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">Equipment</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage Vision Energy products and equipment catalog</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/admin/equipment/new"
               Style="text-transform: none;">
        Add Equipment
    </MudButton>
</div>

<MudPaper Elevation="2" Class="pa-5" Style="border-radius: 12px;">
    <MudTextField @bind-Value="_searchString" Placeholder="Search equipment..."
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" Variant="Variant.Outlined" Class="mb-4" />

    <MudTable Items="@FilteredEquipment" Hover="true" Dense="true" Elevation="0"
              Loading="@_loading" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Catalog Ref</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Featured</MudTh>
            <MudTh>Order</MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Category">@context.Category?.Name</MudTd>
            <MudTd DataLabel="Catalog Ref">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.CatalogReference ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.ApprovalStatus)">
                    @context.ApprovalStatus
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Featured">
                <MudIcon Icon="@(context.IsFeatured ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                         Color="@(context.IsFeatured ? Color.Warning : Color.Default)" Size="Size.Small" />
            </MudTd>
            <MudTd DataLabel="Order">@context.DisplayOrder</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Href="@($"/admin/equipment/edit/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteEquipment(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No equipment found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<Equipment> _equipment = [];
    private bool _loading = true;
    private string _searchString = "";

    private IEnumerable<Equipment> FilteredEquipment => string.IsNullOrEmpty(_searchString)
        ? _equipment
        : _equipment.Where(e =>
            e.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            (e.Category?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.CatalogReference?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await LoadEquipment();

    private async Task LoadEquipment()
    {
        _loading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            _equipment = await context.Equipment
                .Include(e => e.Category)
                .OrderBy(e => e.DisplayOrder)
                .AsNoTracking()
                .ToListAsync();
        }
        finally { _loading = false; }
    }

    private async Task DeleteEquipment(Equipment item)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Equipment",
            $"Are you sure you want to delete \"{item.Title}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var entity = await context.Equipment.FindAsync(item.Id);
            if (entity is not null)
            {
                context.Equipment.Remove(entity);
                await context.SaveChangesAsync();
                Snackbar.Add("Equipment deleted successfully", Severity.Success);
                await LoadEquipment();
            }
        }
    }

    private static Color GetStatusColor(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Draft => Color.Default,
        ApprovalStatus.PendingApproval => Color.Warning,
        ApprovalStatus.Approved => Color.Success,
        ApprovalStatus.Rejected => Color.Error,
        _ => Color.Default
    };
}
