@page "/admin/equipment/new"
@page "/admin/equipment/edit/{Id:int}"
@layout AdminLayout
@attribute [Authorize(Policy = "RequireContentCreator")]
@using OECLWebsite.Data
@using OECLWebsite.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@(IsEdit ? "Edit Equipment" : "New Equipment") — Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-family: 'Rajdhani', sans-serif;">@(IsEdit ? "Edit Equipment" : "Add New Equipment")</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@(IsEdit ? "Update equipment details and settings" : "Add a new equipment item to the catalog")</MudText>
    </div>
    <MudButton Href="/admin/equipment" Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
               Style="text-transform: none;">
        Back to Equipment
    </MudButton>
</div>

<MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px;">
    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_model.Title" Label="Equipment Name" Required="true"
                              RequiredError="Name is required" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int" @bind-Value="_model.CategoryId" Label="Category" Required="true"
                           RequiredError="Category is required" Variant="Variant.Outlined">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.ShortDescription" Label="Short Description"
                              Variant="Variant.Outlined" Lines="2" MaxLength="500"
                              HelperText="Brief overview shown on listing cards (max 500 chars)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.DetailedDescription" Label="Detailed Description"
                              Variant="Variant.Outlined" Lines="8" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.TechnicalSpecs" Label="Technical Specifications (JSON)"
                              Variant="Variant.Outlined" Lines="4"
                              Style="font-family: 'JetBrains Mono', monospace;" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.CatalogReference" Label="Catalog Reference"
                              Variant="Variant.Outlined"
                              HelperText="Vision Energy catalog page reference (e.g. Page 12)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.AvailabilityNote" Label="Availability Note"
                              Variant="Variant.Outlined"
                              HelperText="e.g. Available for rental, Sale only" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <ImageUpload Label="Equipment Icon"
                             ButtonText="Upload Icon"
                             @bind-CurrentImageUrl="_model.IconUrl"
                             Subfolder="equipment/icons" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <ImageUpload Label="Equipment Image"
                             ButtonText="Upload Image"
                             @bind-CurrentImageUrl="_model.ImageUrl"
                             Subfolder="equipment" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_model.DisplayOrder" Label="Display Order"
                                 Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudCheckBox @bind-Value="_model.IsActive" Label="Active" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudCheckBox @bind-Value="_model.IsFeatured" Label="Featured" Color="Color.Warning" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="ApprovalStatus" @bind-Value="_model.ApprovalStatus" Label="Status" Variant="Variant.Outlined">
                    <MudSelectItem T="ApprovalStatus" Value="ApprovalStatus.Draft">Draft</MudSelectItem>
                    <MudSelectItem T="ApprovalStatus" Value="ApprovalStatus.PendingApproval">Submit for Approval</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        <div class="d-flex justify-end gap-3 mt-6">
            <MudButton Variant="Variant.Outlined" Href="/admin/equipment">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(!_formValid || _saving)"
                       OnClick="HandleSave"
                       StartIcon="@Icons.Material.Filled.Save">
                @(_saving ? "Saving..." : "Save Equipment")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;

    private MudForm _form = null!;
    private bool _formValid;
    private bool _saving;
    private EquipmentModel _model = new();
    private List<EquipmentCategory> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        _categories = await context.EquipmentCategories
            .Where(c => c.IsActive)
            .OrderBy(c => c.DisplayOrder)
            .AsNoTracking()
            .ToListAsync();

        if (IsEdit)
        {
            var item = await context.Equipment.AsNoTracking().FirstOrDefaultAsync(e => e.Id == Id);
            if (item is not null)
            {
                _model = new EquipmentModel
                {
                    Title = item.Title,
                    CategoryId = item.CategoryId,
                    ShortDescription = item.ShortDescription,
                    DetailedDescription = item.DetailedDescription,
                    TechnicalSpecs = item.TechnicalSpecs,
                    CatalogReference = item.CatalogReference,
                    AvailabilityNote = item.AvailabilityNote,
                    IconUrl = item.IconUrl,
                    ImageUrl = item.ImageUrl,
                    DisplayOrder = item.DisplayOrder,
                    IsActive = item.IsActive,
                    IsFeatured = item.IsFeatured,
                    ApprovalStatus = item.ApprovalStatus,
                };
            }
        }
    }

    private async Task HandleSave()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            Equipment entity;
            if (IsEdit)
            {
                entity = await context.Equipment.FindAsync(Id) ?? throw new InvalidOperationException("Equipment not found");
            }
            else
            {
                entity = new Equipment();
                context.Equipment.Add(entity);
            }

            entity.Title = _model.Title;
            entity.CategoryId = _model.CategoryId;
            entity.ShortDescription = _model.ShortDescription;
            entity.DetailedDescription = _model.DetailedDescription;
            entity.TechnicalSpecs = _model.TechnicalSpecs;
            entity.CatalogReference = _model.CatalogReference;
            entity.AvailabilityNote = _model.AvailabilityNote;
            entity.IconUrl = _model.IconUrl;
            entity.ImageUrl = _model.ImageUrl;
            entity.DisplayOrder = _model.DisplayOrder;
            entity.IsActive = _model.IsActive;
            entity.IsFeatured = _model.IsFeatured;
            entity.ApprovalStatus = _model.ApprovalStatus;

            await context.SaveChangesAsync();
            Snackbar.Add(IsEdit ? "Equipment updated" : "Equipment created", Severity.Success);
            Navigation.NavigateTo("/admin/equipment");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private class EquipmentModel
    {
        public string Title { get; set; } = string.Empty;
        public int CategoryId { get; set; }
        public string? ShortDescription { get; set; }
        public string? DetailedDescription { get; set; }
        public string? TechnicalSpecs { get; set; }
        public string? CatalogReference { get; set; }
        public string? AvailabilityNote { get; set; }
        public string? IconUrl { get; set; }
        public string? ImageUrl { get; set; }
        public int DisplayOrder { get; set; }
        public bool IsActive { get; set; } = true;
        public bool IsFeatured { get; set; }
        public ApprovalStatus ApprovalStatus { get; set; } = ApprovalStatus.Draft;
    }
}
